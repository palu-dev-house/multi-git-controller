{
  "name": "multi-git-controller",
  "version": "1.0.0",
  "description": "Switch SSH keys between Git accounts",
  "main": "main.js",
  "author": {
    "name": "Palu Dev House",
    "email": "dev@paludevhouse.com"
  },
  "homepage": "https://github.com/palu-dev-house/multi-git-controller",
  "repository": {
    "type": "git",
    "url": "https://github.com/palu-dev-house/multi-git-controller.git"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "semantic-release": "semantic-release"
  },
  "release": {
    "branches": ["main"],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      ["@semantic-release/changelog", { "changelogFile": "CHANGELOG.md" }],
      ["@semantic-release/npm", { "npmPublish": false }],
      ["@semantic-release/git", {
        "assets": ["package.json", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]"
      }],
      "@semantic-release/github"
    ]
  },
  "build": {
    "appId": "com.paludevhouse.multi-git-controller",
    "productName": "Multi-Git Controller",
    "directories": {
      "output": "dist",
      "buildResources": "../build"
    },
    "icon": "../build/icon.png",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "tray-icon*.png"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "darkModeSupport": true
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "palu-dev-house",
      "repo": "multi-git-controller"
    }
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "semantic-release": "^25.0.3"
  }
}
